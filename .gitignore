# Stray PDFs (root copies, sample JDs) stay local — but track the working resume
# inside the workspace so cloud runs have it (repo is private).
*.pdf
!job-search/profile/resume.pdf
!job-search/pipeline/**/*.pdf

# Claude Code memory (project-specific, not for sharing)
.claude/projects/

# Local Claude settings (may contain credentials/permissions — keep local)
.claude/settings.local.json

# Raw resume text dump (regenerable). base-resume.json IS tracked so cloud
# runs have the structured resume.
job-search/profile/_resume_raw.txt

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Stray build artifacts (legacy)
node_modules/
.next/
out/
tsconfig.tsbuildinfo
